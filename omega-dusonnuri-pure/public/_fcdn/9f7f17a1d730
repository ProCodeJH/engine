<script>
Vue.component('layer-view', {
    template: "#layer-view-template",
    props: {
        status : {type : Boolean,default :false},
        idx : {type:String,default:""}
    },
    data: function(){
        return {
            board : {}
        };
    },
    created: function(){

    },
    methods: {
        getBBS : function() {
            var component = this;

            $.ajax({
                url : "/components/bbs/layer/core/ajax.php",
                method : "get",
                data : {
                    _controller : "Board",
                    _method : "get",
                    _idx : component.idx
                },
                dataType : "json",
                success : function(res) {
                    if(!res.success) alert(res.message);
                    else {
                        component.status = true;
                        component.board = res.Board;
                        if(component.idx != "")
                            document.querySelector('html').setAttribute('data-scroll', 'false');
                    }
                }
            });

        },
        close : function() {
            document.querySelector('html').removeAttribute('data-scroll');
            this.status = false;
            this.idx = "";
        }
    },
    computed : {

    },
    watch : {
        idx : function() {
            this.getBBS();
        }
    }
});
</script>
