<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge"/>
    <title>CAFE24 Analytics</title>
</head>
<body>
<script>
    (function() {
        const permanentStorageKey = "cafe24_permanent_id";
        const sessionStorageKey = "cafe24_session_id";

        const getPermanentId = () => {
            const storageId = localStorage.getItem(permanentStorageKey);
            if (storageId) return storageId;

            const newId = "552f75dda7834003a3401159d62ce692.88958e91cd224b46";
            localStorage.setItem(permanentStorageKey, newId);
            return newId;
        };

        const getSessionId = () => {
            const storageId = sessionStorage.getItem(sessionStorageKey);
            if (storageId) return storageId;

            const newId = "e330f24662cc46db95f21a249c3872f1.508582a6468fddeb";
            sessionStorage.setItem(sessionStorageKey, newId);
            return newId;
        };

        const permanentId = getPermanentId();
        const sessionId = getSessionId();

        parent.postMessage(JSON.stringify({
            method: "setIds",
            params: {
                permanentId: permanentId,
                sessionId: sessionId
            }
        }), '*');
    })();
</script>
</body>
</html>
