<script>

	let selectedItem = null;
	let selectedNum;
	let timer;
	const container = document.querySelector('.gate-container');
	const sub = document.querySelector('.gate-sub');
	const prevBtns = document.querySelectorAll('.prev-btn');
	

	
	document.addEventListener('DOMContentLoaded', () => {

		if(window.innerWidth < 1024) {
			moSlide();
		}
		prevBtns.forEach(item => {
			item.addEventListener('click', () => {
				container.classList.remove('active');
				sub.classList.remove('active');
			});
		});

		// gate bg
		let today = new Date();
		let current_hour = today.getHours();

		if(current_hour < 6 || 20 <= current_hour){
			document.querySelector('body').classList.add('night');
		}else{
			document.querySelector('body').classList.remove('night');
		}

		// 1024 이하 사이즈에서 초기화면으로
		window.addEventListener('resize', () => {
			if(window.innerWidth < 1024) {
				moSlide();
			}
		});
	});
	
	function moSlide(){
		var mySwiper = new Swiper('.swiper-container', {
			loop: false,			
			pagination: {
				el: '.swiper-pagination',
				clickable: true
			},
			navigation:{
				prevEl: ".links-slider .status-prev-btn",
				nextEl: ".links-slider .status-next-btn",
			},
			a11y:{
	    		prevSlideMessage: '이전 슬라이드',
	    		nextSlideMessage: '다음 슬라이드',
	    	},
		})
	}
	
	function selectItem(num){
// 		if(selectedNum && (num === selectedNum)) return;

		if(selectedItem){
			selectedItem.classList.remove('selected');
		}
		if(timer) {
			clearTimeout(timer);
		}
		timer = setTimeout(function(){
			document.querySelector('.site' + num).classList.add('selected');
			selectedItem = document.querySelector('.site' + num);
		},10);

		sub.setAttribute("data-sub", num);
		selectedNum = num;
	}
</script>

