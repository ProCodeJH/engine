		<script>
			const youtubeService = {
				/**
				 * noembed.com을 통해 유튜브 정보를 읽어옵니다.
				 */
				fetch: (videoId, desc) => {
					if (!videoId) {
						throw new Error("파라미터가 올바르지 않습니다.");
					}
					
					const url = youtubeService._getUrl(videoId);
					
					fetch("https://noembed.com/embed?url=" + url, {
						signal: AbortSignal.timeout(5_000),
					}).then((response) => {
						return response.json();
					}).then((data) => {
						const { title, thumbnail_url } = data;
						
						youtubeService._render(videoId, { title, thumbnail_url });
					}).catch((error) => {	//읽어오지 못한 경우, 위젯데이터(desc)를 활용합니다.						
						youtubeService._render(videoId, { title: desc });
					})
				},
				
				/**
				 * sns 유튜브 영역에 화면을 그립니다.
				 */
				_render: (videoId, { title = "", thumbnail_url = "" }) => {
					const targetEles = document.querySelectorAll("ul#sns-youtube li[data-video-id='" + videoId + "']");
					targetEles.forEach((li) => {
						li.style.removeProperty("min-height");
						li.classList.remove("back-loading");
						
						const titleEle = li.querySelector("span#title");
						titleEle.innerText = title;
						
						const linkEle = li.querySelector("a#link");
						linkEle.href = youtubeService._getUrl(videoId);
						linkEle.target = "_blank";
						linkEle.title = title + " " + "유튜브 새창열림";

						const imageEle = li.querySelector("img#image");
						imageEle.src = thumbnail_url;
						imageEle.alt = title;
					})
				},
				
				/**
				 * videoId을 통해 Url을 파싱합니다.
				 */
				_getUrl: (videoId) => {
					return "https://www.youtube.com/watch?v=" + videoId;
				}
			}
			
			
			document.addEventListener("DOMContentLoaded", () => {
				
					youtubeService.fetch("mW7BJTXf1FU", "[건보자판기] 새롭게 태어났습니다! 건강보험25시!!");
				
