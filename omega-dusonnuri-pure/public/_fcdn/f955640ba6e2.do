<script type="text/javascript">
	/**
	 *	내 검색어 서비스
	 *	@author gt.kim
	 *	
	 *  dqSearch.js에 의존합니다. (replaceXSS ...)
	 *    - myKeywordService.getMyKeywords();
	 *	  - myKeywordService.add(keyword);
	 *    - myKeywordService.remove(keyword);
	 *    - myKeywordService.removeAll();
	 */
	const myKeywordService = {
		_MY_KEYWORD_KEY: "mykeyword",
		_SEPERATOR: "^%",
	
		/**
		 * MyKeyword 목록을 가져옵니다.
		 */
		getMyKeywords: function () {
			const cookie = myKeywordService._getCookie();
			if (!cookie) {
				return [];
			}
		
			const myKeywords = cookie.split(myKeywordService._SEPERATOR);	
			for (let i = 0; i < myKeywords.length; i++) {
				myKeywords[i] = replaceXSS(myKeywords[i]);
			}
	
			return myKeywords.filter((myKeyword) => myKeyword);  
		},
	
		/**
		 * keyword를 추가합니다.
		 * @param keyword 키워드
		 */
		add: function (keyword) {
			myKeywordService.remove(keyword);
			
			const myKeywords = myKeywordService.getMyKeywords();
			myKeywords.push(keyword);
			
			myKeywordService._setCookie(myKeywords.join(myKeywordService._SEPERATOR));
		},
	
		/**
		 * keyword를 삭제합니다.
		 * @param keyword 키워드
		 */
		remove: function (keyword) {
			const myKeywords = myKeywordService.getMyKeywords();
	
			myKeywordService._setCookie(myKeywords.filter((myKeyword) => myKeyword !== keyword).join(myKeywordService._SEPERATOR));	
		},
	
		/**
		 * keyword를 모두 삭제합니다.
		 * @param keyword 키워드
		 */
		removeAll: function () {
			myKeywordService._setCookie("");	
		},
		
		
		_getCookie: function () {
			//쿠키값 조회
			const cookies = document.cookie.split(";");
			
			for (let i = 0; i < cookies.length; i++) {
				const x = cookies[i].substr(0, cookies[i].indexOf("=")).replace(/^\s+|\s+$/g, "");
				const y = cookies[i].substr(cookies[i].indexOf("=") + 1);
			
				if (x == myKeywordService._MY_KEYWORD_KEY) {
					return unescape(y);
				}
			}
		},
		//쿠키값 설정
		_setCookie: function (value, exdays = 365) {
			const exdate = new Date();
			exdate.setDate(exdate.getDate() + exdays);
			const c_value = escape(value) + (exdays == null ? "" : "; expires=" + exdate.toUTCString());
			document.cookie = myKeywordService._MY_KEYWORD_KEY + "=" + c_value + ";" + "path" + "=" + "/nhis";
		}, 
	};
</script>

<script type="text/javascript">
	document.addEventListener("DOMContentLoaded", () => {		
		const fetchTrendKeywords = () => trendKeywordService.fetchTrendKeywords(10,  //인기검색어
			(data = {}) => {
				const trendKeywords = data["trendKeywords"];
				wbhaza03112m01.showTrendKeywords(trendKeywords);
			}, () => {
				const trendKeywords = [];
				wbhaza03112m01.showTrendKeywords(trendKeywords);
			}, () => {
				
			}, () => {
				
			}
		);
		
		fetchTrendKeywords();
		//setInterval(fetchTrendKeywords, 1000 * 60 * 10);	//10분에 한번씩 인기검색어를 조회합니다.
		
		wbhaza03112m01.showMyKeywords();  //내가 찾은 검색어
	});
	
	const wbhaza03112m01 = {
		showTrendKeywords: (trendKeywords = []) => {	//인기검색어 표출
			const keywordElement = document.querySelector("#searchLayer li.li.li1 > ol");
			$(keywordElement).html(null);  //전부 지움
			
			if (trendKeywords.length != 0) {	//값이 있는 경우, 영역을 표출
				$(document.querySelector("#searchLayer li.li.li1")).show();
			} else {
				$(document.querySelector("#searchLayer li.li.li1")).hide();
			}
			
			trendKeywords.sort((one, theOther) => Number(one.RANKING) - Number(theOther.RANKING)).forEach((trendKeyword) => {
				const { KEYWORD, PREV_RANK, RANKING } = trendKeyword;
				const risesAndFalls = Number(PREV_RANK) - Number(RANKING);	//등락
				
				let risesAndFallsStr = "";
				
				if (risesAndFalls < 0) {
					risesAndFallsStr = '<span class="ranking-state down"><em class="sr-only">하락</em>' + Math.abs(risesAndFalls) + '</span>';
				}
				
				if (risesAndFalls > 0) {
					risesAndFallsStr = '<span class="ranking-state up"><em class="sr-only">상승</em>' + risesAndFalls + '</span>';
				}
				
				if (risesAndFalls == 0) {
					risesAndFallsStr = '<span class="ranking-state same"><em class="sr-only">동일</em>';
				}
				
				const str = '<li role="button" onclick="javascript:wbhaza03112m01.search(' + "'" + KEYWORD + "'" + ');" onkeyup="if(event.key == \'Enter\') {wbhaza03112m01.search(' + "'" + KEYWORD + "'" + ');}" title="새창열림" tabindex="0"><span class="ranking-txt">' + KEYWORD + '</span>' + risesAndFallsStr + '</li>';
				$(keywordElement).append(str);
			});
		},
			
		showMyKeywords: () => {	//최근검색어 표출
		    const myKeywords = myKeywordService.getMyKeywords(); 
		    
			const keywordElement = document.querySelector("#searchLayer li.li.li2 > ul");
			$(keywordElement).html(null);  //전부 지움			
			
			if (myKeywords.length != 0) {	//값이 있는 경우, 영역을 표출
				$(document.querySelector("#searchLayer li.li.li2")).show();
			} else {
				$(document.querySelector("#searchLayer li.li.li2")).hide();
			}
			
			myKeywords.reverse().filter((_, idx) => {
				return idx < 10;	//10건만 표출합니다.
			}).forEach((myKeyword) => { //마지막에 넣은 요소가 먼저 출력되도록 함.
				const str = '<li><span role="button" class="word-txt" onclick="javascript:wbhaza03112m01.search(' + "'" + myKeyword + "'" + ')" title="새창열림" tabindex="0">' + myKeyword + '</span><button class="btn btn-ico ico-del sm" onclick="javascript:wbhaza03112m01.remove(' + "'" + myKeyword + "'" + ');"><span class="sr-only">삭제</span></button></li>';
				$(keywordElement).append(str);
			});
		},
		
		add: (keyword) => {
			myKeywordService.add(keyword);
			wbhaza03112m01.showMyKeywords();
		},
		
		remove: (keyword) => {
			myKeywordService.remove(keyword);
			wbhaza03112m01.showMyKeywords();
		},
		
		removeAll: () => {
			myKeywordService.removeAll();
			wbhaza03112m01.showMyKeywords();
		},
		
		search: (keyword) => {
			const realKeyword = keyword ?? document.getElementById("query_main").value;
			go_searchMain(realKeyword);
			wbhaza03112m01.add(realKeyword);
		}
	}
	
	
	
</script>

