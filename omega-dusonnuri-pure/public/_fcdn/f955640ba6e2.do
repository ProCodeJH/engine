									<script>
										document.addEventListener("DOMContentLoaded", () => {
											const currentZoom = sessionStorage.getItem(ZOOM_LEVEL_KEY);
											
											if (currentZoom) {
												document.body.style.zoom = parseFloat(currentZoom);
											}
										});
										
										
										const [MIN_SCREEN_ZOOM, MAX_SCREEN_ZOOM] = [0.25, 2.0];
										const ZOOM_LEVEL_KEY = "zoomLevel";
										
										function screenZoomIn() {
											const currentZoom = parseFloat(document.body.style.zoom || 1.0);
											
											if (MAX_SCREEN_ZOOM <= currentZoom) {
												return;
											}
											
											const zoomIn = currentZoom + 0.05;
											
											document.body.style.zoom = zoomIn;
											sessionStorage.setItem(ZOOM_LEVEL_KEY, zoomIn);
										}
										function screenZoomOut() {
											const currentZoom = parseFloat(document.body.style.zoom || 1.0);
											
											if (currentZoom <= MIN_SCREEN_ZOOM) {
												return;
											}
											
											const zoomOut = currentZoom - 0.05;
											
											document.body.style.zoom = zoomOut;
											sessionStorage.setItem(ZOOM_LEVEL_KEY, zoomOut);
										}
									</script>
									<ul class="drop-list zoom_list">
										
										<li><button type="button" class="item-link" onclick="screenZoomIn();"><i class="iconset btn_increase"></i>화면 확대</button></li>
										<li><button type="button" class="item-link" onclick="screenZoomOut();"><i class="iconset btn_decrease"></i>화면 축소</button></li>
