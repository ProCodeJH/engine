				html += '                            </div>';
				html += '                            <div class="today_tit">';
				html += '                                <p><label onclick="fn_closeTodayLayer(this);" for="input-popReserInsert--01">오늘은 그만보기</label></p>';
				html += '                            </div>';
				html += '                        </div>';
				html += '                        <button type="button" onclick="fn_closeLayer(this);" class="btn btn-save">닫기</button>';
				html += '                    </div>';
				html += '                </div>';
				html += '            </div>';
				html += '        </div>';
				
				$(".popup-container", $("#mainLayerPopup")).append(html);
				
				$("#"+popupId, $("#mainLayerPopup")).draggable({
