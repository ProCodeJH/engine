	function getTopBannerList() {
		var request = ComLib.ajaxReqObj("/lp/z/a/001/getTopBannerList.do", {});
		request.done(function(data) {
			$("#pageTopBannerList").html("");
			
			if(data.list.length > 0) {
				for (var i = 0; i < data.list.length; i++) {
					var info = data.list[i];
					var bnrId = info.bnrId;
					var bnrTitlNm = info.bnrTitlNm;
					var bnrCnte = info.bnrCnte;
					var bltnPttnCd = info.bltnPttnCd;
					var linkUrlAddr = info.linkUrlAddr;
					var bnrWidSize = info.bnrWidSize
					var bnrHghtSize = info.bnrHghtSize
					
					var html = "";
					html += "<div class=\"swiper-slide\">";
					html += "  <div class=\"d-flex align-center\">";
					html += "    <a href=\""+ linkUrlAddr +"\" target=\"_self\" >";
					html += "      <span class=\"img-wrap\">";
					html += "        <img src=\"/lp/z/a/001/image.do?id="+ bnrId +"&cd="+ bltnPttnCd +"\" alt=\"\" style=\"width: "+ bnrWidSize +"px;height:"+ bnrHghtSize +"px;border-radius: 10px;\" >";
					html += "      </span>";
					html += "      <div class=\"top-banner__cont\">";
					html += "        <h1 class=\"top-banner__tit\">"+ bnrTitlNm +"</h1>";
					html += "        <p class=\"top-banner__txt\">"+ bnrCnte +"</p>";
					html += "      </div>";
					html += "      <p>";
					html += "        자세히 보기";
					html += "        <span class=\"img-wrap\">";
					html += "          <img src=\"/resources/assets/image/common/icon/icon-link--detail.svg\" alt=\"\">";
					html += "        </span>";
					html += "      </p>";
					html += "    </a>";
					html += "  </div>";
					html += "</div>";
					
					$("#pageTopBannerList").append(html);
				}
				
			} else { //기본설정
			}
			
			setBanner(data.list.length);
			
		});
		request.fail(function (xhr, statusText, errorThrown) {//실패는 공통으로 처리
			defaultTopBanner();
		});
	}
	
