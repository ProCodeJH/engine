				html += '                    <button type="button" onclick="fn_closeLayer(this);" class="cust_close_btn" title="팝업 닫기"></button>';
				html += '                </div>';
				html += '                <div class="popup-foot">';
				html += '                    <div class="btn-wrap flex-center">';
				html += '                        <div class="today_close">';
				html += '                            <div class="form-wrap">';
				html += '                                <div class="form-check">';
				html += '                                    <label for="input-popReserInsert--01" class="d-flex align-center">';
