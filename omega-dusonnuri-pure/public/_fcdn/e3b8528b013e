	function setBanner(list) {
		if(list > 0) {
			if(ComLib.isEmpty(get_cookie("bannerClose"))){
				$("#pageBanner").removeClass("display-hide");
				$("#closeImg").css("rotate", "0deg");
				$("#closeTxt").text("팝업닫기");
			} else {
				$("#closeImg").css("rotate", "180deg");
				$("#closeTxt").text("팝업열기");
			}
		}
		
		$("#btnCloseBanner").on("click", function() {
			if($("#pageBanner").hasClass('display-hide')) {
				removeBannerCookie();
				$("#closeImg").css("rotate", "0deg");
				$("#closeTxt").text("팝업닫기");
				$("#pageBanner").removeClass('display-hide');
			} else {
				setBannerCookie();
				$("#closeImg").css("rotate", "180deg");
				$("#closeTxt").text("팝업열기");
				$("#pageBanner").addClass('display-hide');
			}
		});
		
		$("#btnCloseBannerToday").on("click", function(){
			if($("#pageBanner").hasClass('display-hide')) {
				removeBannerCookie();
				$("#closeImg").css("rotate", "0deg");
				$("#closeTxt").text("팝업닫기");
				$("#pageBanner").removeClass('display-hide');
			} else {
				setBannerCookie();
				$("#closeImg").css("rotate", "180deg");
				$("#closeTxt").text("팝업열기");
				$("#pageBanner").addClass('display-hide');
			}
		});
		
		var setBannerCookie = function() {
			var expires = "";
			var now = new Date();
			var midnight = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1)
			var remain = midnight - now;
			
			if (remain > 0) {
				var date = new Date();
				date.setTime(date.getTime() + remain);
				expires = "; expires=" + date.toUTCString();
			}
			document.cookie = "bannerClose=Y" + expires + "; path=/";
		}
		
		var removeBannerCookie = function() {
			var expires = "";
			var now = new Date();
			var midnight = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1)
			var remain = midnight - now;
			
			if (remain > 0) {
				var date = new Date();
				date.setTime(date.getTime() + remain);
				expires = "; expires=" + date.toUTCString();
			}
			document.cookie = "bannerClose=N" + expires + "; path=/ ; Max-Age=0";
		}
		
		if(list > 0) {
			$("#btnCloseBanner").show();
		}
	}
	
