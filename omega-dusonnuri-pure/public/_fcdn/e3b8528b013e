function fn_closeLayer(_this) {
	var _layerId = ComLib.isEmpty(_this) ? "" : $(_this).closest(".popup-content").attr("id");
	$("#"+_layerId).last().fadeIn(300).css("display", "none").remove();
	
	if($("#"+_layerId).length > 0) {
		$("#"+_layerId).last().fadeIn(150).css("display", "block");
	}
}

function fn_closeTodayLayer(_this) {
	var _layerId = ComLib.isEmpty(_this) ? "" : $(_this).closest(".popup-content").attr("id");
	
	setLayerPopupCookie(_layerId);
	
	fn_closeLayer(_this);
};


var setLayerPopupCookie = function(_layerId) {
	var expires = "";
	var now = new Date();
	var midnight = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1)
	var remain = midnight - now;
	
	if (remain > 0) {
		var date = new Date();
		date.setTime(date.getTime() + remain);
		expires = "; expires=" + date.toUTCString();
	}
	document.cookie = _layerId+"=Y" + expires + "; path=/";
}

