function replaceAll(str, searchStr, replaceStr){
	return str.split(searchStr).join(replaceStr);
}

var timer;

function fnExtendTime() {
	clearTimeout(timer);
	
	var paramMap = {
			 "userId" : loginId
		};	
	
	$.ajax({
		url:		'/login/checkExistUserInfo.do',
		dataType:	"json",
		data:		paramMap,
		method:		"POST",
		async:		false,
		success: function(data){
			clearTimeout(timer);
			fnTimer(1800);
		}
	});
}

function fn_set(sec) {
	var h = Math.floor(sec/3600);
	var m = Math.floor((sec - h * 3600) / 60);
	var s = sec - h * 3600 - m * 60;
	var hh = ((h < 10) ? '0' : '') + h;
	var mm = ((m < 10) ? '0' : '') + m;
	var ss = ((s < 10) ? '0' : '') + s;
	return mm +":"+ ss;
}

function fnTimer(time) {
	$("[name=timeTxt]").text(fn_set(time));
	
	if(time >= 0) {
		timer = setTimeout(fnTimer, 1000, --time);
	} else {
		var wwidth = window.innerWidth;
		if(wwidth > 780) { // pc버전일째만
			doLogout();
		}
	}
}



