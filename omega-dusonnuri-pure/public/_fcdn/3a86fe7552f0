var APP4YOU_SMART_POPUP = {

    /**
     * slickSlider 실행
     *
     * @param sliderParam
     */
    runSlickSlider: function (sliderParam) {

        // EC$ 로딩이 완료되지 않았으면 재시도
        if (typeof EC$ == 'undefined') {

            console.log('EC$ Loading...');

            setTimeout(function () {
                APP4YOU_SMART_POPUP.runSlickSlider(sliderParam)
            }, 200);

            return;
        }

        (function ($) {

            $(document).ready(function () {
                try {

                    // slick 플러그인 로딩이 완료되지 않았으면 재시도
                    if (typeof $().smartPopupSlick == 'undefined') {

                        console.log('slick Loading...');

                        setTimeout(function () {
                            APP4YOU_SMART_POPUP.runSlickSlider(sliderParam)
                        }, 200);

                        return;
                    }

                    // HTML 팝업인지 확인 (HTML 팝업의 targetObj는 '#app-smart-popup-slider-html-'로 시작함)
                    var isHtmlPopup = sliderParam.targetObj.indexOf('#app-smart-popup-slider-html-') > -1;

                    // 슬라이더 적용
                    var slickOptions = {
                        dots: isHtmlPopup ? false : true, // HTML 팝업일 경우 dots를 표시하지 않음
                        autoplay: sliderParam.autoplay,
                        autoplaySpeed: sliderParam.autoplaySpeed,
                        arrows: sliderParam.arrows
                    };

                    var $targetObj = $(sliderParam.targetObj);

                    // HTML 팝업일 경우 슬라이더 변경시 카운터 업데이트를 위한 이벤트 추가
                    if (isHtmlPopup) {

                        const shadowHost = document.querySelector(".app-smart-popup-container");
                        const shadowRoot = shadowHost.shadowRoot;
                        const innerElement = shadowRoot.querySelector('.app-smart-popup');
                        $targetObj = $(innerElement).find(sliderParam.targetObj);

                        // slick 1.8.1 버전 호환성을 위해 afterChange 또는 onAfterChange 둘 다 설정
                        slickOptions.afterChange = function(slick, currentSlide) {
                            // 즉시 카운터 업데이트
                            var $counter = $(this).closest('.app-smart-popup').find('.smart-popup-counter .current');
                            if ($counter.length > 0) {
                                $counter.text(currentSlide + 1);
                            }

                            // 커스텀 슬라이드 변경 콜백 실행 (makePopup에서 설정한 경우)
                            if (sliderParam.onSlideChange && typeof sliderParam.onSlideChange === 'function') {
                                sliderParam.onSlideChange(currentSlide);
                            }
                        };

                        slickOptions.onAfterChange = function(slick, currentSlide) {
                            // 즉시 카운터 업데이트
                            var $counter = $(this).closest('.app-smart-popup').find('.smart-popup-counter .current');
                            if ($counter.length > 0) {
                                $counter.text(currentSlide + 1);
                            }

                            // 커스텀 슬라이드 변경 콜백 실행 (makePopup에서 설정한 경우)
                            if (sliderParam.onSlideChange && typeof sliderParam.onSlideChange === 'function') {
                                sliderParam.onSlideChange(currentSlide);
                            }
                        };

                        // 초기화 시에도 카운터 업데이트를 위한 이벤트 추가
                        slickOptions.init = function(slick) {
                            // 초기화 즉시 카운터 업데이트
                            var $counter = $(this).closest('.app-smart-popup').find('.smart-popup-counter .current');
                            if ($counter.length > 0) {
                                $counter.text('1');
                            }

                            // 커스텀 초기화 콜백 실행 (makePopup에서 설정한 경우)
                            if (sliderParam.onSlideChange && typeof sliderParam.onSlideChange === 'function') {
                                sliderParam.onSlideChange(0);
                            }
                        };
                    }

                    $targetObj.smartPopupSlick(slickOptions);

                    // 슬라이더 아이콘 적용 (HTML 팝업이 아닐 경우에만)
                    if (!isHtmlPopup && sliderParam.slideButtonType === 'square') {
                        $targetObj.find('.app-smart-popup-slider-dots').addClass('app-smart-popup-bar');
                    }

                    // APP4U-2976 : 슬라이드 설정이 완료되면 보이기
                    $targetObj.closest('.app-smart-popup').show();

                    // HTML 팝업인 경우 초기 카운터 값을 1로 설정
                    if (isHtmlPopup) {
                        $targetObj.closest('.app-smart-popup').find('.smart-popup-counter .current').text('1');
                    }

                    // APP4U-3023 : 마우스오버 해제시 슬라이드처리 동작하도록 추가.
                    $targetObj.on('mouseleave', function(event){
                        $(this).smartPopupSlick('play');
                    });

                } catch (e) {
                    if (typeof(e) == 'object' && e.stack && window.console) {
                        console.error(e);
                    }
                }
            });

        }(EC$));
