		if( isMobile == true && popEndDateInt >= popNowDateInt ) {
			var cookieCheck = fn_LayerPopYn("layerPopYn");
			if( cookieCheck != "N" ){
				$(".pop_ie_notice").remove();
				$("#dmLayerPopup").css("display", "");
			}
		}
	}
	
	// 레이어 팝업  쿠키가져오기
	function fn_LayerPopYn( name ){
		var cookie = document.cookie;
		if( document.cookie != "" ){
			var cookie_array = cookie.split("; ");
			for ( var index in cookie_array ){
				var cookie_name = cookie_array[index].split("=");
				if( cookie_name[0] == name ){
					//console.log("["+cookie_name[0]+"]==["+cookie_name[1]+"]=================================================")
					return cookie_name[1];
				}
			}
		}
		return;
	}
	
	function fn_LayerPopClose( chkVal, chkId, layerId ){
		var chk = $("input:checkbox[id='" + chkId + "']").is(":checked");
		if( chk ){
			var date = new Date();
			date.setDate(date.getDate() + 1);
			document.cookie = escape(chkVal) + "=" + escape('N') + "; expires=" + date.toUTCString();
		}
		$("#" + layerId).css({"display":"none"});
	}
	
