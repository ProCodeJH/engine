	function sendFastResv(){
		
		if( $("#fastResvAgree1:checked").length <= 0 ){
			alert("개인정보 이용에 동의해주세요.");			
			return;
		}
		
		if( !$("#fastResvUserNm").val().trim() ){
			alert("상담 받으실 분 이름을 입력해주세요.");
			$("#fastResvUserNm").focus();
			return;
		}
		
		if( !$("#fastResvMobile1").val().trim() ){
			alert("상담 받으실 전화번호 앞자리를 입력해주세요.");
			$("#fastResvMobile1").focus();
			return;
		}
		
		if( !$("#fastResvMobile2").val().trim() ){
			alert("상담 받으실 전화번호 가운데 자리를 입력해주세요.");
			$("#fastResvMobile2").focus();
			return;
		}
		
		if( !$("#fastResvMobile3").val().trim() ){
			alert("상담 받으실 전화번호 마지막 자리를 입력해주세요.");
			$("#fastResvMobile3").focus();
			return;
		}
		
		var userNm = $("#fastResvUserNm").val();
		var phone = $("#fastResvMobile1").val() + "-" +$("#fastResvMobile2").val() + "-" + $("#fastResvMobile3").val(); 
		
		$.ajax({
			type: "POST",
			url: "/sendFastResv.do",
			data: { "userNm": userNm, "phone": phone },
			success: function( result ){
				
				$("#fastResvUserNm").val("");
				$("#fastResvMobile1").val("");
				$("#fastResvMobile2").val("");
				$("#fastResvMobile3").val("");
				$("#fastResvAgree1").prop("checked", false);
				
				if( result == "Y" ){
					$("#SuccessLayer").hide();
					$("#AgreeLayer").hide();
					alert("신청 완료 되었습니다.");					
				}else{
					alert("신청 도중 장애가 발생 하였습니다.\n재신청 바랍니다.");
					location.reload();
				}
				
			} 
		});
		
	}
	
