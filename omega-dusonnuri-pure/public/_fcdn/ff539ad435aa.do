<body style="margin:0;border:none;-ms-touch-action:none;" onload="oninitframework()">
<script type="text/javascript">
//로그인여부
var gv_loginYn = '';
//적용프로파일
var profile = 'PROD';
function oninitframework(){
	
	//브라우저 버전
	var browserInfo = comLib.browserVersionCheck();
	var osInfo = comLib.OSInfoDev();
	var gv_osInfo = new Object();
	gv_osInfo["navigatorUserAgent"] = navigator.userAgent;
	gv_osInfo["browserInfo"] = browserInfo;
	gv_osInfo["osInfo"] = osInfo;
	//console.dir(gv_osInfo);
	if(browserInfo.browserName == "IE"){
		if(browserInfo.browserVersion <= 9){
			location.href = "/install.do";
		}
	}else if(browserInfo.browserName != "Chrome"){
		location.href = "/install.do";
	}
	
	var screeninfo = [
          {"id":"ScreenDeskTop","type":"desktop","key":"nhis-hpbs","httptimeout":"600","themeid":"theme::nhis-hpbs","xadl":"nhis-hpbs.xadl.js"}
	];
	
	nexacro._initHTMLSysEvent(window, document);			
	nexacro._initEnvironment(screeninfo);
          //nexacro._prepareManagerFrame(onloadframework, [{family:'webfont', style:'normal', weight:400},{family:'webfontBold', style:'normal', weight:700}]);
          nexacro._prepareManagerFrame(onloadframework);
          nexacro.setInitialVariable( "application", "gv_loginYn", gv_loginYn );
          nexacro.setInitialVariable( "application", "gv_profile", profile );
          nexacro.setInitialVariable( "application", "gv_osInfo", jsonLib.stringify(gv_osInfo) );
}
function onloadframework()
{
	nexacro._loadADL();
}
function onfinalframework()
{
	
}

</script>
