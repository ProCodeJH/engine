		//$(_this).text();
		
		var searchText = "";
		if("울릉도" == $(_this).text()){
			searchText = "울릉";
		}else if("독도" == $(_this).text()){
			searchText = "울릉";
		}else if("영종도" == $(_this).text()){
			searchText = "옹진군";		
		}else{
			searchText = $(_this).text();
		}
		
		$("#SK1").click();		
		
		$("#CT").val(CT);
		
		if(LOC == ""){			
			$("#LOC").val(searchText);			
			
		}else{
			$("#LOC").val(LOC);
		}
		
		$("#jisa_search").val(searchText);
		
		fn_retrieveBranchList(1);
		
	}
	
