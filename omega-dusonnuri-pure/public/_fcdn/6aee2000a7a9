	<script type="text/javascript">
		function isMobile() {
			var userAgent = navigator.userAgent;
			
			if(userAgent.match(/iPhone|iPod|Android|Windows CE|BlackBerry|Symbian|Windows Phone|webOS|Opera Mini|Opera Mobi|POLARIS|IEMobile|lgtelecom|nokia|SonyEricsson/i) != null || userAgent.match(/LG|SAMSUNG|Samsung/) != null) {
				return true;
			}else{
				return false;
			}
		}
		
		function showEventPopup() {
			// 이벤트 시작 종료시간(yyyymmddhhmm 형태)
			var EVENT_START = "202008100900";		// 8월 10일 09시 00분
			var EVENT_FINISH = "202008312330";		// 8월 31일 23시 30분
			
			// 응모기간 검증
			var now = new Date();
			var year = now.getFullYear();
			var month = (now.getMonth() + 1)
			var date = now.getDate();
			var hour = now.getHours();
			var minute = now.getMinutes();
			
			month = (month > 9 ? '' : '0') + month;
			date = (date > 9 ? '' : '0') + date;
			hour = (hour > 9 ? '' : '0') + hour;
			minute = (minute > 9 ? '' : '0') + minute;
			
			var yyyymmddhhmm = year + month + date + hour + minute;
			
			if(EVENT_START <= yyyymmddhhmm && yyyymmddhhmm <= EVENT_FINISH) {
				var popupUrl;
				var top = 5;
				var left = 5;
				var width;
				var height;
				
				if(isMobile() == true) {
					popupUrl = "/html/popup/20200810/pop_mo_200810.html";
					width = 580;
					height = 925;
				} else {
					popupUrl = "/html/popup/20200810/pop_pc_200810.html";
					width = 670;
					height = 474;
				}
				
				left = left + width + 10;
				
				// 팝업 띄우는 경로
				window.open(popupUrl, "eventPop", "width=" + width + ",height=" + height + ",top=" + top + ",left=" + (screen.availWidth - left));
			} else {
				return;
			}
		}
		
		$(document).ready(function() {
			showEventPopup();
		})
	</script>
